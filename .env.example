# API Keys
Z_AI_API_KEY=your_upstream_key_here

# App Settings
PORT=8000
LOG_LEVEL=INFO
ENABLE_USAGE_STATS=true
DATABASE_URL=sqlite+aiosqlite:///data/stats.db

# Admin Credentials
ADMIN_USERNAME=admin
# ADMIN_PASSWORD - will be generated randomly if not set

# MCP URLs
SEARCH_MCP_URL=https://api.z.ai/api/mcp/web_search_prime/sse
READER_MCP_URL=https://api.z.ai/api/mcp/web_reader/sse
ZREAD_MCP_URL=https://api.z.ai/api/mcp/zread/sse
